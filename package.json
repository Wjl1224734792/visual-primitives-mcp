{
  "name": "visual-primitives-mcp",
  "version": "1.0.1",
  "description": "基于 DeepSeek Visual Primitives 论文的多模态空间锚定 MCP 服务器，将视觉模型的精确坐标推理能力封装为标准 MCP 工具",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "vision",
    "multimodal",
    "deepseek",
    "visual-primitives",
    "grounding",
    "spatial-reasoning"
  ],
  "author": "Wjl1224734792",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wjl1224734792/visual-primitives-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Wjl1224734792/visual-primitives-mcp/issues"
  },
  "homepage": "https://github.com/Wjl1224734792/visual-primitives-mcp#readme",
  "files": [
    "dist",
    "src/templates",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "hono": "^4.0.0",
    "ffmpeg-static": "^5.2.0",
    "sharp": "^0.33.0",
    "pdf-poppler": "^0.2.3"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "prettier": "^3.3.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "tsx": "^4.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
