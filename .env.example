# ============================================================
# Visual Primitives MCP — 环境变量配置
# ============================================================
# 复制此文件为 .env：
#   cp .env.example .env
# ============================================================

# ---------- 必填：默认模型配置（所有工具共用） ----------
# 视觉模型 API 基础 URL（OpenAI 兼容接口）
VISION_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API 密钥
VISION_API_KEY=sk-xxxxxxxx

# 默认模型名称（describe/locate/ocr/video 未单独配置时使用此值）
VISION_MODEL_NAME=qwen3.5-plus

# ---------- 可选：按工具独立覆盖（任意字段，不配则回退默认值） ----------
# 每个工具可独立配置 baseUrl / apiKey / model，自由组合不同厂商模型
# VISION_DESCRIBE_BASE_URL=https://another-provider.com/v1
# VISION_DESCRIBE_API_KEY=sk-xxxxxxxx
# VISION_DESCRIBE_MODEL=qwen3-vl-plus
# VISION_LOCATE_BASE_URL=https://another-provider.com/v1
# VISION_LOCATE_API_KEY=sk-xxxxxxxx
# VISION_LOCATE_MODEL=qwen3-vl-plus
# VISION_OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VISION_OCR_API_KEY=sk-xxxxxxxx
# VISION_OCR_MODEL=qwen3-vl-ocr
# VISION_VIDEO_BASE_URL=https://another-provider.com/v1
# VISION_VIDEO_API_KEY=sk-xxxxxxxx
# VISION_VIDEO_MODEL=qwen3-vl-plus

# ---------- 可选：其他配置 ----------
# 坐标归一化精度（0-100 或 0-1000），默认 0-1000
# COORDINATE_PRECISION=0-1000

# 传输协议（stdio / sse / http-stream），默认 stdio
# MCP_TRANSPORT=stdio

# 日志级别（debug / info / warn / error），默认 info
# LOG_LEVEL=info

# API 调用超时（毫秒），默认 45000
# TIMEOUT_MS=45000

# 会话过期时间（秒），默认 3600（1 小时）
# SESSION_TTL_SECONDS=3600

# SQLite 数据库文件路径，默认 ./data/grounding.db
# DB_PATH=./data/grounding.db

# SSE / HTTP Stream 模式端口，默认 3000
# PORT=3000
